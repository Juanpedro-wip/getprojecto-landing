# Copia in .env e compila. Senza SMTP i lead vengono comunque salvati in data/waitlist.json.
PORT=3000
WAITLIST_TO=info@getprojecto.ch

# SMTP per la notifica email (consigliato: Resend, Postmark, Infomaniak, o l'SMTP del dominio)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Projecto <noreply@getprojecto.ch>"

# Google Analytics 4 (facoltativo): di default usa l'ID di produzione nel codice (render.js).
# Decommenta con un valore vuoto per DISATTIVARE lo snippet (es. in sviluppo), o con un altro ID per sovrascrivere.
# GA_MEASUREMENT_ID=
